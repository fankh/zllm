// Small-M weight-stationary f16 matvec: C[M,N] = A[M,K] * W[K,N], W is f16 stored
// [K,N] row-major (same layout vk_up_f16t produces for wv/w2). One workgroup (64
// threads) per output column n; each f16 weight is read once and applied to all M
// activation rows (M<=8). The spec-decode verify counterpart of decode f16 matvec.
// Compile: glslangValidator --target-env vulkan1.3 -V batched_matvec_f16.comp -o batched_matvec_f16.spv
#version 450 core
#extension GL_EXT_shader_explicit_arithmetic_types_float16 : require

layout(local_size_x = 64) in;

layout(binding = 0) readonly  buffer WF { float16_t wf[]; };  // weights [K,N]
layout(binding = 1) readonly  buffer X_ { float x[];      };  // activations [M,K]
layout(binding = 2) writeonly buffer O_ { float outp[];   };  // [M,N]
layout(binding = 3) uniform   P_ { uint M; uint N; uint K; uint pad; uint gx; } p;

const uint MAXM = 8u;
shared float partial[64];   // reused across M reductions (acc[] in registers) — occupancy

void main() {
    uint row = gl_WorkGroupID.x + gl_WorkGroupID.y * p.gx;   // output column n
    uint t = gl_LocalInvocationID.x;
    if (row >= p.N) { return; }
    float acc[MAXM];
    for (uint m = 0u; m < MAXM; m++) acc[m] = 0.0;
    for (uint k = t; k < p.K; k += 64u) {
        float wgt = float(wf[k * p.N + row]);                // W[k,n], [K,N] layout
        for (uint m = 0u; m < p.M; m++) acc[m] += wgt * x[m * p.K + k];
    }
    for (uint m = 0u; m < p.M; m++) {
        barrier();
        partial[t] = acc[m];
        barrier();
        for (uint s = 32u; s > 0u; s >>= 1u) { if (t < s) partial[t] += partial[t + s]; barrier(); }
        if (t == 0u) outp[m * p.N + row] = partial[0];
    }
}
