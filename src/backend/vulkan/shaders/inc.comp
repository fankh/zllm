// Barrier-coherence probe: b[i] += 1.0. Run as N separate dispatches with a
// barrier between each; the result must be N if cross-dispatch memory is made
// visible. Under an execution-only barrier (no cache flush) a stale L1 read
// would yield < N — exposing whether this GPU's L2 is coherent for sequential
// compute (and thus whether the cheap barrier is correctness-safe).
#version 450 core
layout(local_size_x = 64) in;
layout(binding = 0) buffer B_ { float b[]; };
layout(binding = 1) uniform P_ { uint n; uint p1; uint p2; uint p3; } p;
void main() {
    uint i = gl_GlobalInvocationID.x;
    if (i >= p.n) { return; }
    b[i] = b[i] + 1.0;
}
