#version 450 core
#extension GL_EXT_shader_explicit_arithmetic_types_float16 : require
layout(local_size_x = 64) in;
layout(binding = 0) readonly  buffer F_ { float src[]; };
layout(binding = 1) writeonly buffer H_ { float16_t dst[]; };
layout(binding = 2) uniform   P_ { uint n; uint p0; uint p1; uint p2; } p;
void main() { uint i = gl_GlobalInvocationID.x; if (i >= p.n) { return; } dst[i] = float16_t(src[i]); }
