// Same probe, but the buffer is `coherent` (AMD: sets the GLC bit — writes
// write-through to L2, reads bypass L1). If this reads correctly under an
// execution-only barrier, coherent access + exec dependency is a cheap,
// correct alternative to the full cache-flush barrier.
#version 450 core
layout(local_size_x = 64) in;
layout(binding = 0) coherent buffer B_ { float b[]; };
layout(binding = 1) uniform P_ { uint n; uint p1; uint p2; uint p3; } p;
void main() {
    uint i = gl_GlobalInvocationID.x;
    if (i >= p.n) { return; }
    b[i] = b[i] + 1.0;
}
