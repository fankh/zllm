// Q4_K coopmat prefill GEMM (Phase 2.1, register-blocked):
// C[M,N] = A[M,K] * dequant(W)[K,N], A=activations(fp16), W=Q4_K [N,K].
// 128x128 output tile per workgroup. 16 wave32 subgroups in a 4x4 grid, each
// register-caching a 2x2 grid of 16x16 accumulator fragments. Per BK=32 K-chunk
// (one Q4_K sub-block): stage 128x32 of A and a dequantized 32x128 weight tile
// into LDS, then 2 k-slices of 4 coopMatMulAdds per subgroup between one barrier
// pair. M,N mult of 128; K mult of 256. fp32 accumulate.
// Tuning ledger (1024-tok prefill GPU-exec, glslang 16.3, 2026-07-06):
//   BK=16 (original) 348ms | BK=32 340ms (+2%, SHIPPED) | column-grouped Bs
//   reads 370ms (LDS write bank conflicts) | 2x4 frag tile @256 threads 352ms
//   (staging parallelism loss). Kernel is insensitive to the classic levers —
//   the next real steps need a profiler (RGP) or register-prefetch double
//   buffering (glslang miscompiled multi-register-array kernels before; risky).
// Compile: C:/tools/glslang/bin/glslangValidator --target-env vulkan1.3 -V coopmat_q4k_gemm.comp -o coopmat_q4k_gemm.spv
#version 450 core
#extension GL_KHR_cooperative_matrix          : require
#extension GL_KHR_memory_scope_semantics      : require
#extension GL_KHR_shader_subgroup_basic       : require
#extension GL_EXT_shader_explicit_arithmetic_types_float16 : require
#pragma use_vulkan_memory_model

layout(local_size_x = 512) in;   // 16 subgroups of 32 (wave32)

layout(binding = 0) readonly  buffer A_  { float16_t A[];  };  // activations [M,K]
layout(binding = 1) readonly  buffer WQ_ { uint      wq[]; };  // raw Q4_K weights [N,K]
layout(binding = 2) writeonly buffer C_  { float     C[];  };  // [M,N]
layout(binding = 3) uniform   P_ { uint M; uint N; uint K; uint nb; } p;

// BK=32 = ONE Q4_K sub-block per K-chunk: the per-column scale unpack runs once
// per chunk (BK=16 recomputed it twice per sub-block), lo is always 0, and each
// chunk feeds 2 k-slices of coopMatMulAdds between one barrier pair (8 MulAdds
// vs 4) — half the barrier + staging-loop overhead per K. LDS 8KB+8KB.
const uint BM = 128u;
const uint BN = 128u;
const uint BK = 32u;
const uint MM = 2u;   // M-fragments per subgroup
const uint MN = 2u;   // N-fragments per subgroup
shared float16_t As[BM * BK];   // 128x32 = 8KB
shared float16_t Bs[BK * BN];   // 32x128 = 8KB
shared float dscLDS[BN];        // cached per-row dequant scale
shared float dmnLDS[BN];

void main() {
    uint tileM = gl_WorkGroupID.y * BM;
    uint tileN = gl_WorkGroupID.x * BN;
    uint sg = gl_SubgroupID;       // 0..15
    uint sr = sg / 4u;             // subgroup row 0..3 → M-rows [sr*32 ..]
    uint scg = sg % 4u;            // subgroup col 0..3 → N-cols [scg*32 ..]
    uint tid = gl_LocalInvocationID.x;

    coopmat<float, gl_ScopeSubgroup, 16, 16, gl_MatrixUseAccumulator> acc[2][2];
    for (uint i = 0u; i < MM; i = i + 1u)
        for (uint j = 0u; j < MN; j = j + 1u)
            acc[i][j] = coopmat<float, gl_ScopeSubgroup, 16, 16, gl_MatrixUseAccumulator>(0.0);

    for (uint k0 = 0u; k0 < p.K; k0 += BK) {
        uint b = k0 / 256u;
        uint sub = (k0 / 32u) % 8u;
        uint lo = k0 % 32u;
        for (uint i = tid; i < BM * BK; i += 512u) {
            uint r = i / BK; uint c = i % BK;
            As[i] = A[(tileM + r) * p.K + k0 + c];
        }
        for (uint i = tid; i < BN; i += 512u) {
            uint n = tileN + i;
            uint blk = (n * p.nb + b) * 36u;
            vec2 dd = unpackHalf2x16(wq[blk]);
            uint u0 = wq[blk + 1u]; uint u1 = wq[blk + 2u]; uint u2 = wq[blk + 3u];
            uint u3 = ((u2 >> 4u) & 0x0f0f0f0fu) | (((u1 >> 6u) & 0x03030303u) << 4u);
            uint uaux = u1 & 0x3f3f3f3fu;
            u1 = (u2 & 0x0f0f0f0fu) | (((u0 >> 6u) & 0x03030303u) << 4u);
            u2 = uaux; u0 = u0 & 0x3f3f3f3fu;
            float scf; float mnf;
            if (sub < 4u) { scf = float((u0 >> (sub * 8u)) & 0xffu); mnf = float((u2 >> (sub * 8u)) & 0xffu); }
            else          { scf = float((u1 >> ((sub - 4u) * 8u)) & 0xffu); mnf = float((u3 >> ((sub - 4u) * 8u)) & 0xffu); }
            dscLDS[i] = dd.x * scf;
            dmnLDS[i] = dd.y * mnf;
        }
        barrier();
        for (uint i = tid; i < BK * BN; i += 512u) {
            // NOTE: (nn=i/BK, kk=i%BK) column-grouped reads were tried for
            // global coalescing and LOST (~9%): the transposed LDS writes
            // (stride BN) bank-conflict; L0 already absorbs the strided reads.
            uint kk = i / BN; uint nn = i % BN;
            uint blk = ((tileN + nn) * p.nb + b) * 36u;
            uint local = lo + kk;
            uint qs0 = blk + 4u + (sub / 2u) * 8u;
            uint word = wq[qs0 + local / 4u];
            uint byte = (word >> ((local % 4u) * 8u)) & 0xffu;
            uint q = ((sub & 1u) == 1u) ? (byte >> 4u) : (byte & 0x0fu);
            Bs[i] = float16_t(dscLDS[nn] * float(q) - dmnLDS[nn]);
        }
        barrier();

        for (uint kk = 0u; kk < BK; kk += 16u) {
            coopmat<float16_t, gl_ScopeSubgroup, 16, 16, gl_MatrixUseA> af[2];
            for (uint i = 0u; i < MM; i = i + 1u)
                coopMatLoad(af[i], As, (sr * 32u + i * 16u) * BK + kk, BK, gl_CooperativeMatrixLayoutRowMajor);
            coopmat<float16_t, gl_ScopeSubgroup, 16, 16, gl_MatrixUseB> bf[2];
            for (uint j = 0u; j < MN; j = j + 1u)
                coopMatLoad(bf[j], Bs, kk * BN + scg * 32u + j * 16u, BN, gl_CooperativeMatrixLayoutRowMajor);
            for (uint i = 0u; i < MM; i = i + 1u)
                for (uint j = 0u; j < MN; j = j + 1u)
                    acc[i][j] = coopMatMulAdd(af[i], bf[j], acc[i][j]);
        }
        barrier();
    }

    for (uint i = 0u; i < MM; i = i + 1u) {
        for (uint j = 0u; j < MN; j = j + 1u) {
            uint r0 = tileM + sr * 32u + i * 16u;
            uint c0 = tileN + scg * 32u + j * 16u;
            coopMatStore(acc[i][j], C, r0 * p.N + c0, p.N, gl_CooperativeMatrixLayoutRowMajor);
        }
    }
}
