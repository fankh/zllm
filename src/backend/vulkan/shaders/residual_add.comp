// Residual add: x[i] += y[i] (fold attn/ffn output back into the residual stream).
#version 450 core
layout(local_size_x = 64) in;
layout(binding = 0) buffer X_ { float x[]; };
layout(binding = 1) readonly buffer Y_ { float y[]; };
layout(binding = 2) uniform P_ { uint n; uint p0; uint p1; uint p2; } p;
void main() { uint i = gl_GlobalInvocationID.x; if (i >= p.n) { return; } x[i] = x[i] + y[i]; }
