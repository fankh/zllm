// Phase 2.0 spike: a single 16x16x16 cooperative-matrix multiply.
// One subgroup (wave32 on RDNA3.5) computes C[16,16] = A[16,16] * B[16,16].
// A,B are row-major float16; C is row-major float32 (the fp32 accumulator
// config, better for the long-K reductions the real GEMM will do).
// Proves the KHR cooperative-matrix path end to end (glslang -> SPIR-V -> ash
// -> RDNA3 WMMA). Compile: glslangValidator --target-env vulkan1.3 -V this -o coopmat_matmul.spv
#version 450 core
#extension GL_KHR_cooperative_matrix          : require
#extension GL_KHR_memory_scope_semantics      : require
#extension GL_EXT_shader_explicit_arithmetic_types_float16 : require
#pragma use_vulkan_memory_model

layout(local_size_x = 32) in;

layout(binding = 0) readonly  buffer A_ { float16_t a[]; };
layout(binding = 1) readonly  buffer B_ { float16_t b[]; };
layout(binding = 2) writeonly buffer C_ { float     c[]; };

void main() {
    coopmat<float16_t, gl_ScopeSubgroup, 16, 16, gl_MatrixUseA> matA;
    coopmat<float16_t, gl_ScopeSubgroup, 16, 16, gl_MatrixUseB> matB;
    coopmat<float, gl_ScopeSubgroup, 16, 16, gl_MatrixUseAccumulator> acc =
        coopmat<float, gl_ScopeSubgroup, 16, 16, gl_MatrixUseAccumulator>(0.0);

    coopMatLoad(matA, a, 0u, 16u, gl_CooperativeMatrixLayoutRowMajor);
    coopMatLoad(matB, b, 0u, 16u, gl_CooperativeMatrixLayoutRowMajor);
    acc = coopMatMulAdd(matA, matB, acc);
    coopMatStore(acc, c, 0u, 16u, gl_CooperativeMatrixLayoutRowMajor);
}
