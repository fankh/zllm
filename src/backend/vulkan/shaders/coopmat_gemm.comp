// LDS-blocked dense fp16 cooperative-matrix GEMM: C[M,N] = A[M,K] * B[K,N]
// (row-major; fp16 inputs, fp32 accumulate). One workgroup = 4 wave32
// subgroups arranged 2x2, computing a 64x64 output tile; each subgroup holds a
// 2x2 grid of 16x16 accumulator fragments. Each K-step stages a 64x16 slice of
// A and a 16x64 slice of B into LDS, then every subgroup loads its fragments
// from LDS and accumulates via coopMatMulAdd. This is the compute core of the
// Q4_K prefill GEMM (Phase 2.1) minus the dequant — used to measure the raw
// coopmat throughput vs the current wgpu f32 path. M,N,K must be multiples of 64/16.
// Compile: glslangValidator --target-env vulkan1.3 -V coopmat_gemm.comp -o coopmat_gemm.spv
#version 450 core
#extension GL_KHR_cooperative_matrix          : require
#extension GL_KHR_memory_scope_semantics      : require
#extension GL_KHR_shader_subgroup_basic       : require
#extension GL_EXT_shader_explicit_arithmetic_types_float16 : require
#pragma use_vulkan_memory_model

layout(local_size_x = 128) in;   // 4 subgroups of 32 (wave32)

layout(binding = 0) readonly  buffer A_ { float16_t A[]; };  // [M,K]
layout(binding = 1) readonly  buffer B_ { float16_t B[]; };  // [K,N]
layout(binding = 2) writeonly buffer C_ { float     C[]; };  // [M,N]
layout(binding = 3) uniform   P_ { uint M; uint N; uint K; uint pad; } p;

const uint BM = 64u;
const uint BN = 64u;
const uint BK = 16u;
shared float16_t As[BM * BK];   // 64x16
shared float16_t Bs[BK * BN];   // 16x64

void main() {
    uint tileM = gl_WorkGroupID.y * BM;
    uint tileN = gl_WorkGroupID.x * BN;
    uint sg = gl_SubgroupID;          // 0..3
    uint sr = sg / 2u;                // subgroup row (0..1) -> output rows [sr*32 ..]
    uint sc = sg % 2u;                // subgroup col (0..1) -> output cols [sc*32 ..]
    uint tid = gl_LocalInvocationID.x;

    coopmat<float, gl_ScopeSubgroup, 16, 16, gl_MatrixUseAccumulator> acc00, acc01, acc10, acc11;
    acc00 = coopmat<float, gl_ScopeSubgroup, 16, 16, gl_MatrixUseAccumulator>(0.0);
    acc01 = acc00; acc10 = acc00; acc11 = acc00;

    for (uint k0 = 0u; k0 < p.K; k0 += BK) {
        for (uint i = tid; i < BM * BK; i += 128u) {
            uint r = i / BK; uint c = i % BK;
            As[i] = A[(tileM + r) * p.K + k0 + c];
        }
        for (uint i = tid; i < BK * BN; i += 128u) {
            uint r = i / BN; uint c = i % BN;
            Bs[i] = B[(k0 + r) * p.N + tileN + c];
        }
        barrier();

        coopmat<float16_t, gl_ScopeSubgroup, 16, 16, gl_MatrixUseA> a0, a1;
        coopMatLoad(a0, As, (sr * 32u + 0u) * BK, BK, gl_CooperativeMatrixLayoutRowMajor);
        coopMatLoad(a1, As, (sr * 32u + 16u) * BK, BK, gl_CooperativeMatrixLayoutRowMajor);
        coopmat<float16_t, gl_ScopeSubgroup, 16, 16, gl_MatrixUseB> b0, b1;
        coopMatLoad(b0, Bs, sc * 32u + 0u, BN, gl_CooperativeMatrixLayoutRowMajor);
        coopMatLoad(b1, Bs, sc * 32u + 16u, BN, gl_CooperativeMatrixLayoutRowMajor);

        acc00 = coopMatMulAdd(a0, b0, acc00);
        acc01 = coopMatMulAdd(a0, b1, acc01);
        acc10 = coopMatMulAdd(a1, b0, acc10);
        acc11 = coopMatMulAdd(a1, b1, acc11);
        barrier();
    }

    uint r0 = tileM + sr * 32u;
    uint c0 = tileN + sc * 32u;
    coopMatStore(acc00, C, (r0 + 0u)  * p.N + c0 + 0u,  p.N, gl_CooperativeMatrixLayoutRowMajor);
    coopMatStore(acc01, C, (r0 + 0u)  * p.N + c0 + 16u, p.N, gl_CooperativeMatrixLayoutRowMajor);
    coopMatStore(acc10, C, (r0 + 16u) * p.N + c0 + 0u,  p.N, gl_CooperativeMatrixLayoutRowMajor);
    coopMatStore(acc11, C, (r0 + 16u) * p.N + c0 + 16u, p.N, gl_CooperativeMatrixLayoutRowMajor);
}
