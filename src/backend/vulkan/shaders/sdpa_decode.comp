// Decode GQA SDPA, parallel: ONE workgroup per query head (was one thread per
// head — 1 CU, with a float[128] register array that spilled to scratch). Each
// of hd threads owns one head-dimension: q·k is a shared-mem reduction across
// threads, the online (flash) softmax runs once per cached position, and thread
// d carries a single accumulator av (no spill). Uses n_head CUs instead of 1.
#version 450 core
layout(local_size_x = 64) in;        // one thread per head-dim (hd <= 64)
layout(binding = 0) readonly  buffer Q_  { float q[];    };  // [n_head*hd]
layout(binding = 1) readonly  buffer KC_ { float kc[];   };  // [seq, n_kv*hd]
layout(binding = 2) readonly  buffer VC_ { float vc[];   };
layout(binding = 3) writeonly buffer O_  { float outp[]; };  // [n_head*hd]
layout(binding = 4) uniform   P_ { uint n_head; uint n_kv; uint hd; uint seq_len; } p;
shared float red[64];
shared float s_score;
void main() {
    uint h = gl_WorkGroupID.x;                 // one workgroup per head
    uint d = gl_LocalInvocationID.x;           // head-dimension index
    uint kvh = h / (p.n_head / p.n_kv);
    float scale = 1.0 / sqrt(float(p.hd));
    float qd = (d < p.hd) ? q[h * p.hd + d] : 0.0;
    float av = 0.0; float mx = -1e30; float l = 0.0;
    for (uint t = 0u; t < p.seq_len; t++) {
        uint kb = (t * p.n_kv + kvh) * p.hd;
        red[d] = (d < p.hd) ? qd * kc[kb + d] : 0.0;
        barrier();
        for (uint st = 32u; st > 0u; st >>= 1u) { if (d < st) { red[d] += red[d + st]; } barrier(); }
        if (d == 0u) { s_score = red[0] * scale; }
        barrier();
        float s = s_score;
        float mn = max(mx, s); float corr = exp(mx - mn); float pe = exp(s - mn);
        l = l * corr + pe;
        if (d < p.hd) { av = av * corr + pe * vc[kb + d]; }
        mx = mn;
        barrier();
    }
    if (d < p.hd) { outp[h * p.hd + d] = av / l; }
}
